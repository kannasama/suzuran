# Copy to .env and fill in values for local development
DATABASE_URL=postgres://suzuran:suzuran@localhost:5432/suzuran
JWT_SECRET=change-me-in-production-use-a-long-random-string
PORT=3000
LOG_LEVEL=info

# WebAuthn — set RP_ID to your domain (e.g. music.example.com) in production
RP_ID=localhost
RP_ORIGIN=http://localhost:3000

# AcoustID API key for acoustic fingerprint lookups. Free key at https://acoustid.biz/login
# Can also be set (or updated without restart) via the Settings UI → General.
# ACOUSTID_KEY=your-acoustid-key

# Directory where uploaded images (theme backgrounds, etc.) are stored.
# Mount this path as a Docker volume to persist uploads across restarts.
# UPLOADS_DIR=/app/uploads

# Path to your music collection on the host, mounted into the container.
# This is the path you reference when creating a library in the UI.
# MUSIC_DIR=/path/to/your/music
